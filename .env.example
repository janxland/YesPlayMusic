VUE_APP_NETEASE_API_URL=/api
VUE_APP_ELECTRON_API_URL=/api
VUE_APP_ELECTRON_API_URL_DEV=http://127.0.0.1:10754
VUE_APP_LASTFM_API_KEY=
VUE_APP_LASTFM_API_SHARED_SECRET=
DEV_SERVER_PORT=8080

# 生产环境静态资源 CDN 路径（vue.config.js publicPath，留空则使用 /）
# 示例：https://cdn.example.com/www/music/dist/
VUE_APP_PUBLIC_PATH=

# 开发环境 API 代理目标（vue.config.js devServer.proxy）
DEV_SERVER_API_PROXY_TARGET=http://127.0.0.1:3000
DEV_SERVER_API_PATH_REWRITE=/

# 腾讯云 COS 部署（scripts/deploy-cdn.js）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_PREFIX=www/music/dist
COS_DOMAIN=
COS_CDN_DOMAIN=
COS_ANONYMOUS=false
